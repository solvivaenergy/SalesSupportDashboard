# Odoo connection
ODOO_URL=https://solviva-energy.odoo.com
ODOO_DB=solviva-energy
ODOO_USER=your.email@solvivaenergy.com
ODOO_API_KEY=your_odoo_api_key_here

# Optional: password fallback if no API key
ODOO_PASSWORD=

# Dashboard access password (server-side gate). Leave empty to disable auth (dev only).
APP_PASSWORD=change_me_to_a_strong_passphrase

# Optional: stable session key (if unset, sessions reset on every restart)
FLASK_SECRET_KEY=
